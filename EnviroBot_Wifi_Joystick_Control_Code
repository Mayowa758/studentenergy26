// ========== MOTOR CONTROL ==========
void setMotor(int left, int right){
    digitalWrite(motor1Pin1, left > 0);
    digitalWrite(motor1Pin2, left < 0);
    digitalWrite(motor2Pin1, right > 0);
    digitalWrite(motor2Pin2, right < 0);

    int pwmLeft = abs(left);
    int pwmRight = abs(right);

    if(pwmLeft > 0 && pwmLeft < 80)
        pwmLeft = 80;

    if(pwmRight > 0 && pwmRight < 80)
        pwmRight = 80;

    ledcWrite(enable1Pin,pwmLeft);
    ledcWrite(enable2Pin,pwmRight);
}

// ========== JOYSTICK ==========
