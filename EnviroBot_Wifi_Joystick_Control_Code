// ========== SERVOS ==========
void handleServo1() {
  servo1.write(server.arg("val").toInt());
  server.send(200);
}

void handleServo2() {
  servo2.write(server.arg("val").toInt());
  server.send(200);
}

void logData(String type, int value) {
  File file = LittleFS.open("/log.csv", FILE_APPEND);

  if (!file) {
    Serial.println("Failed to open file");
    return;
  }

  String line = type + "," + String(value) + "\n";
  file.print(line);
  file.close();
}

void handleLog() {
  File file = LittleFS.open("/log.csv", FILE_READ);

  if (!file) {
    server.send(500, "text/plain", "No log file");
    return;
  }

  String data = file.readString();
  file.close();

  server.send(200, "text/plain", data);
}

// ========== SENSORS ==========
void handleSoil() {
  int val = analogRead(soilPin);
  logData("soil", val);
  server.send(200, "text/plain", String(val));
}

void handleTurbidity() {
  int val = analogRead(turbidityPin);
  logData("turbidity", val);
  server.send(200, "text/plain", String(val));
}

// ========== SETUP ==========
void setup() {
  Serial.begin(115200);

  pinMode(motor1Pin1, OUTPUT);
  pinMode(motor1Pin2, OUTPUT);
  pinMode(motor2Pin1, OUTPUT);
  pinMode(motor2Pin2, OUTPUT);

  ledcAttach(enable1Pin, freq, resolution);
  ledcAttach(enable2Pin, freq, resolution);

  servo1.attach(servo1Pin);
  servo2.attach(servo2Pin);

  WiFi.softAP(ssid, password);

  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.on("/joystick", handleJoystick);
  server.on("/servo1", handleServo1);
  server.on("/servo2", handleServo2);
  server.on("/soil", handleSoil);
  server.on("/turbidity", handleTurbidity);
  server.on("/log", handleLog);

  server.begin();

  if (!LittleFS.begin(true)) {
    Serial.println("LittleFS mount failed");
    return;
  }
  Serial.println("LittleFS ready");
}

// ========== LOOP ==========
void loop() {
  server.handleClient();
}
